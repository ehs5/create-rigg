{
  "name": "create-rigg",
  "version": "0.0.6",
  "description": "Create Node.js TypeScript projects with a Unified Toolchain",
  "keywords": [
    "backend",
    "create-rigg",
    "express",
    "fastify",
    "framework",
    "hono",
    "node",
    "nodejs",
    "oxfmt",
    "oxlint",
    "rigg",
    "scaffolder",
    "toolchain",
    "tsdown",
    "tsx",
    "typescript",
    "vite+",
    "vite-plus",
    "viteplus",
    "vitest"
  ],
  "license": "MIT",
  "author": "Espen Steen",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehs5/rigg.git"
  },
  "bin": {
    "create-rigg": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "template"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check && tsc --noEmit",
    "dev": "tsx src/index.ts",
    "build": "tsdown src/index.ts",
    "prepublishOnly": "git diff --exit-code && git diff --cached --exit-code && oxlint && oxfmt && tsc --noEmit && vitest run && pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cross-spawn": "^7.0.6",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.3"
}
